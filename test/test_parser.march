-- Tests for the Parser module.

mod TestParser do

-- Helper: write a temp file and parse it
pfn parse_src(name, src, include_private) do
  let path = "/tmp/march_doc_test_" ++ name ++ ".march"
  match File.write(path, src) do
    Ok(_) -> Parser.parse_file(path, include_private)
    Err(_) -> None
  end
end

describe "Parser" do

  describe "direct type construction" do

    test "FnEntry fields" do
      let e = FnEntry("hello", "hello(x : Int) : String", Some("A doc"), false, 0)
      assert (Parser.is_pub(e) == true)
      assert (Parser.is_prv(e) == false)
      assert (Parser.entry_priv(e) == false)
      match e do FnEntry(n, s, d, p, _) ->
        assert (n == "hello")
        assert (s == "hello(x : Int) : String")
        assert (d == Some("A doc"))
        assert (p == false)
      end
    end

    test "FnEntry private" do
      let e = FnEntry("secret", "secret()", None, true, 0)
      assert (Parser.is_pub(e) == false)
      assert (Parser.is_prv(e) == true)
      assert (Parser.entry_priv(e) == true)
      match e do FnEntry(n, s, d, p, _) ->
        assert (n == "secret")
        assert (s == "secret()")
        assert (d == None)
        assert (p == true)
      end
    end

    test "TypeEntry fields" do
      let t = TypeEntry("Color", "Color = Red | Blue", Some("A color type"), 0)
      match t do TypeEntry(n, s, d, _) ->
        assert (n == "Color")
        assert (s == "Color = Red | Blue")
        assert (d == Some("A color type"))
      end
    end

    test "TypeEntry no doc" do
      let t = TypeEntry("Shape", "Shape = Circle | Square", None, 0)
      match t do TypeEntry(n, s, d, _) ->
        assert (n == "Shape")
        assert (String.contains(s, "Circle"))
        assert (d == None)
      end
    end

    test "IfaceEntry fields" do
      let i = IfaceEntry("Show", "Show", Some("Show things"), Cons(("show", "fn show(self) : String"), Nil), 0)
      match i do IfaceEntry(n, s, d, ms, _) ->
        assert (n == "Show")
        assert (s == "Show")
        assert (d == Some("Show things"))
        assert (List.length(ms) == 1)
      end
    end

    test "IfaceEntry no doc" do
      let i = IfaceEntry("Eq", "Eq", None, Nil, 0)
      match i do IfaceEntry(n, s, d, ms, _) ->
        assert (n == "Eq")
        assert (d == None)
        assert (List.is_empty(ms))
      end
    end

    test "ModuleInfo fields" do
      let m = ModuleInfo("MyMod", Some("Module doc"), Cons(FnEntry("f", "f()", None, false, 0), Nil), Cons(TypeEntry("T", "T = A", None, 0), Nil), Nil, "")
      assert (Parser.info_name(m) == "MyMod")
      match m do ModuleInfo(n, c, fns, ts, is, _) ->
        assert (n == "MyMod")
        assert (c == Some("Module doc"))
        assert (List.length(fns) == 1)
        assert (List.length(ts) == 1)
        assert (List.is_empty(is))
      end
    end

    test "ModuleInfo no comment" do
      let m = ModuleInfo("Bare", None, Nil, Nil, Nil, "")
      assert (Parser.info_name(m) == "Bare")
      match m do ModuleInfo(_, c, fns, ts, is, _) ->
        assert (c == None)
        assert (List.is_empty(fns))
        assert (List.is_empty(ts))
        assert (List.is_empty(is))
      end
    end

    test "info_name extracts name" do
      assert (Parser.info_name(ModuleInfo("A", None, Nil, Nil, Nil, "")) == "A")
      assert (Parser.info_name(ModuleInfo("B", Some("d"), Nil, Nil, Nil, "")) == "B")
      assert (Parser.info_name(ModuleInfo("Xyz123", None, Nil, Nil, Nil, "")) == "Xyz123")
    end

    test "is_pub and is_prv are inverses" do
      let pub = FnEntry("f", "", None, false, 0)
      let prv = FnEntry("g", "", None, true, 0)
      assert (Parser.is_pub(pub) == true)
      assert (Parser.is_prv(pub) == false)
      assert (Parser.is_pub(prv) == false)
      assert (Parser.is_prv(prv) == true)
      assert (Parser.is_pub(pub) != Parser.is_prv(pub))
      assert (Parser.is_pub(prv) != Parser.is_prv(prv))
    end

    test "entry_priv matches private flag" do
      assert (Parser.entry_priv(FnEntry("a", "", None, false, 0)) == false)
      assert (Parser.entry_priv(FnEntry("b", "", None, true, 0)) == true)
      assert (Parser.entry_priv(FnEntry("c", "", Some("d"), false, 0)) == false)
      assert (Parser.entry_priv(FnEntry("d", "", Some("d"), true, 0)) == true)
    end

    test "multiple FnEntries in list" do
      let fns = Cons(FnEntry("a", "a()", None, false, 0), Cons(FnEntry("b", "b()", Some("doc"), true, 0), Nil))
      assert (List.length(fns) == 2)
      match List.head_opt(fns) do
        Some(e) -> assert (Parser.is_pub(e))
        None -> assert false
      end
    end

    test "multiple TypeEntries in list" do
      let types = Cons(TypeEntry("A", "A = X", None, 0), Cons(TypeEntry("B", "B = Y", Some("d"), 0), Nil))
      assert (List.length(types) == 2)
    end

    test "FnEntry with long signature" do
      let e = FnEntry("map", "map(list : List(a), f : fn(a) : b) : List(b)", Some("Maps a function over a list"), false, 0)
      match e do FnEntry(n, s, d, _, _) ->
        assert (n == "map")
        assert (String.contains(s, "List"))
        assert (String.contains(s, "fn"))
        match d do Some(t) -> assert (String.contains(t, "Maps")) | None -> assert false end
      end
    end

    test "ModuleInfo with many entries" do
      let fns = Cons(FnEntry("a", "", None, false, 0), Cons(FnEntry("b", "", None, true, 0), Cons(FnEntry("c", "", None, false, 0), Nil)))
      let types = Cons(TypeEntry("T1", "", None, 0), Cons(TypeEntry("T2", "", None, 0), Nil))
      let ifaces = Cons(IfaceEntry("I1", "", None, Nil, 0), Nil)
      let m = ModuleInfo("Big", Some("Big module"), fns, types, ifaces, "")
      match m do ModuleInfo(n, c, fs, ts, is, _) ->
        assert (n == "Big")
        assert (List.length(fs) == 3)
        assert (List.length(ts) == 2)
        assert (List.length(is) == 1)
        match c do Some(t) -> assert (t == "Big module") | None -> assert false end
      end
    end

    test "FnEntry doc variants" do
      let e1 = FnEntry("f1", "f1()", Some("doc1"), false, 0)
      let e2 = FnEntry("f2", "f2()", Some("doc2"), false, 0)
      let e3 = FnEntry("f3", "f3()", None, false, 0)
      match e1 do FnEntry(_, _, d, _, _) -> assert (d == Some("doc1")) end
      match e2 do FnEntry(_, _, d, _, _) -> assert (d == Some("doc2")) end
      match e3 do FnEntry(_, _, d, _, _) -> assert (d == None) end
    end

    test "FnEntry name variants" do
      assert (Parser.is_pub(FnEntry("alpha", "alpha()", None, false, 0)))
      assert (Parser.is_pub(FnEntry("beta", "beta(x)", None, false, 0)))
      assert (Parser.is_pub(FnEntry("gamma", "gamma(x, y)", None, false, 0)))
      assert (Parser.is_prv(FnEntry("delta", "delta()", None, true, 0)))
      assert (Parser.is_prv(FnEntry("epsilon", "epsilon(x)", None, true, 0)))
    end

    test "TypeEntry sig variants" do
      let t1 = TypeEntry("A", "A = X | Y", None, 0)
      let t2 = TypeEntry("B", "B = X(Int) | Y(String)", Some("docs"), 0)
      let t3 = TypeEntry("C", "ptype C = P | Q", None, 0)
      match t1 do TypeEntry(n, s, _, _) ->
        assert (n == "A")
        assert (String.contains(s, "X"))
        assert (String.contains(s, "Y"))
      end
      match t2 do TypeEntry(n, s, d, _) ->
        assert (n == "B")
        assert (String.contains(s, "Int"))
        assert (d == Some("docs"))
      end
      match t3 do TypeEntry(n, s, _, _) ->
        assert (n == "C")
        assert (String.contains(s, "ptype"))
      end
    end

    test "IfaceEntry method lists" do
      let i1 = IfaceEntry("I1", "I1", None, Nil, 0)
      let i2 = IfaceEntry("I2", "I2", None, Cons(("m1", "fn m1() : Int"), Nil), 0)
      let i3 = IfaceEntry("I3", "I3", Some("doc"), Cons(("m1", ""), Cons(("m2", ""), Nil)), 0)
      match i1 do IfaceEntry(_, _, _, ms, _) -> assert (List.is_empty(ms)) end
      match i2 do IfaceEntry(_, _, _, ms, _) -> assert (List.length(ms) == 1) end
      match i3 do IfaceEntry(_, _, d, ms, _) ->
        assert (List.length(ms) == 2)
        assert (d == Some("doc"))
      end
    end

    test "ModuleInfo comment variants" do
      let m1 = ModuleInfo("M1", None, Nil, Nil, Nil, "")
      let m2 = ModuleInfo("M2", Some("short"), Nil, Nil, Nil, "")
      let m3 = ModuleInfo("M3", Some("a longer module comment with details"), Nil, Nil, Nil, "")
      assert (Parser.info_name(m1) == "M1")
      assert (Parser.info_name(m2) == "M2")
      assert (Parser.info_name(m3) == "M3")
      match m1 do ModuleInfo(_, c, _, _, _, _) -> assert (c == None) end
      match m2 do ModuleInfo(_, c, _, _, _, _) -> assert (c == Some("short")) end
      match m3 do ModuleInfo(_, c, _, _, _, _) ->
        match c do
          Some(t) -> assert (String.contains(t, "longer"))
          None -> assert false
        end
      end
    end

    test "FnEntry equality checks" do
      let e1 = FnEntry("f", "f()", None, false, 0)
      let e2 = FnEntry("f", "f()", None, false, 0)
      let e3 = FnEntry("g", "g()", None, true, 0)
      match e1 do FnEntry(n1, _, _, _, _) ->
        match e2 do FnEntry(n2, _, _, _, _) -> assert (n1 == n2) end
      end
      match e3 do FnEntry(n3, _, _, p3, _) ->
        assert (n3 == "g")
        assert (p3 == true)
      end
    end

    test "info_name on various modules" do
      assert (Parser.info_name(ModuleInfo("String", None, Nil, Nil, Nil, "")) == "String")
      assert (Parser.info_name(ModuleInfo("List", None, Nil, Nil, Nil, "")) == "List")
      assert (Parser.info_name(ModuleInfo("IO", None, Nil, Nil, Nil, "")) == "IO")
      assert (Parser.info_name(ModuleInfo("File", None, Nil, Nil, Nil, "")) == "File")
      assert (Parser.info_name(ModuleInfo("MyApp", None, Nil, Nil, Nil, "")) == "MyApp")
      assert (Parser.info_name(ModuleInfo("Unknown", None, Nil, Nil, Nil, "")) == "Unknown")
    end

    test "is_pub on many entries" do
      assert (Parser.is_pub(FnEntry("a", "", None, false, 0)) == true)
      assert (Parser.is_pub(FnEntry("b", "", Some("d"), false, 0)) == true)
      assert (Parser.is_pub(FnEntry("c", "c(x)", None, false, 0)) == true)
      assert (Parser.is_pub(FnEntry("d", "", None, true, 0)) == false)
      assert (Parser.is_pub(FnEntry("e", "", Some("d"), true, 0)) == false)
    end

    test "is_prv on many entries" do
      assert (Parser.is_prv(FnEntry("a", "", None, true, 0)) == true)
      assert (Parser.is_prv(FnEntry("b", "", Some("d"), true, 0)) == true)
      assert (Parser.is_prv(FnEntry("c", "c(x)", None, true, 0)) == true)
      assert (Parser.is_prv(FnEntry("d", "", None, false, 0)) == false)
      assert (Parser.is_prv(FnEntry("e", "", Some("d"), false, 0)) == false)
    end

    test "entry_priv consistent with is_pub is_prv" do
      let pub = FnEntry("pub", "", None, false, 0)
      let prv = FnEntry("prv", "", None, true, 0)
      assert (Parser.entry_priv(pub) == false)
      assert (Parser.entry_priv(prv) == true)
      assert (Parser.is_pub(pub) == !Parser.entry_priv(pub))
      assert (Parser.is_prv(pub) == Parser.entry_priv(pub))
      assert (Parser.is_pub(prv) == !Parser.entry_priv(prv))
      assert (Parser.is_prv(prv) == Parser.entry_priv(prv))
    end

    test "ModuleInfo fn list operations" do
      let fns = Cons(FnEntry("x", "x()", Some("xd"), false, 0), Cons(FnEntry("y", "y()", None, true, 0), Nil))
      let m = ModuleInfo("M", None, fns, Nil, Nil, "")
      match m do ModuleInfo(_, _, fs, _, _, _) ->
        assert (List.length(fs) == 2)
        assert (!List.is_empty(fs))
        match List.head_opt(fs) do
          Some(e) ->
            assert (Parser.is_pub(e))
            match e do FnEntry(n, _, d, _, _) ->
              assert (n == "x")
              assert (d == Some("xd"))
            end
          None -> assert false
        end
      end
    end

    test "TypeEntry list operations" do
      let ts = Cons(TypeEntry("T1", "T1 = A", Some("td"), 0), Cons(TypeEntry("T2", "T2 = B", None, 0), Nil))
      assert (List.length(ts) == 2)
      match List.head_opt(ts) do
        Some(te) -> match te do TypeEntry(n, _, d, _) ->
          assert (n == "T1")
          assert (d == Some("td"))
        end
        None -> assert false
      end
    end

    test "IfaceEntry list operations" do
      let is = Cons(IfaceEntry("I1", "I1", Some("id"), Nil, 0), Cons(IfaceEntry("I2", "I2", None, Nil, 0), Nil))
      assert (List.length(is) == 2)
      match List.head_opt(is) do
        Some(ie) -> match ie do IfaceEntry(n, _, d, _, _) ->
          assert (n == "I1")
          assert (d == Some("id"))
        end
        None -> assert false
      end
    end

    test "FnEntry sig contains params" do
      let e = FnEntry("map", "map(list : List(a), f : fn(a) : b) : List(b)", None, false, 0)
      match e do FnEntry(_, s, _, _, _) ->
        assert (String.contains(s, "map"))
        assert (String.contains(s, "list"))
        assert (String.contains(s, "List"))
        assert (String.contains(s, "fn"))
        assert (String.byte_size(s) > 10)
      end
    end

    test "ModuleInfo with all entry types" do
      let fns = Cons(FnEntry("f", "", None, false, 0), Nil)
      let types = Cons(TypeEntry("T", "", None, 0), Nil)
      let ifaces = Cons(IfaceEntry("I", "", None, Nil, 0), Nil)
      let m = ModuleInfo("AllTypes", Some("Has everything"), fns, types, ifaces, "")
      assert (Parser.info_name(m) == "AllTypes")
      match m do ModuleInfo(n, c, fs, ts, is, _) ->
        assert (n == "AllTypes")
        assert (!List.is_empty(fs))
        assert (!List.is_empty(ts))
        assert (!List.is_empty(is))
        match c do Some(t) -> assert (String.contains(t, "everything")) | None -> assert false end
      end
    end

    test "FnEntry various signatures" do
      let e1 = FnEntry("read", "read(path : String) : Result(String, Error)", None, false, 0)
      let e2 = FnEntry("write", "write(path : String, data : String) : Result((), Error)", None, false, 0)
      let e3 = FnEntry("delete", "delete(path : String) : Result((), Error)", Some("Deletes a file"), false, 0)
      match e1 do FnEntry(n, s, _, _, _) ->
        assert (n == "read")
        assert (String.contains(s, "Result"))
        assert (String.contains(s, "path"))
      end
      match e2 do FnEntry(n, s, _, _, _) ->
        assert (n == "write")
        assert (String.contains(s, "data"))
      end
      match e3 do FnEntry(n, _, d, _, _) ->
        assert (n == "delete")
        assert (d == Some("Deletes a file"))
      end
    end

    test "TypeEntry various constructors" do
      let t1 = TypeEntry("Option", "Option(a) = Some(a) | None", None, 0)
      let t2 = TypeEntry("Result", "Result(a, e) = Ok(a) | Err(e)", Some("Result type"), 0)
      let t3 = TypeEntry("List", "List(a) = Nil | Cons(a, List(a))", None, 0)
      match t1 do TypeEntry(n, s, _, _) ->
        assert (n == "Option")
        assert (String.contains(s, "Some"))
        assert (String.contains(s, "None"))
      end
      match t2 do TypeEntry(n, s, d, _) ->
        assert (n == "Result")
        assert (String.contains(s, "Ok"))
        assert (String.contains(s, "Err"))
        assert (d == Some("Result type"))
      end
      match t3 do TypeEntry(n, s, _, _) ->
        assert (n == "List")
        assert (String.contains(s, "Nil"))
        assert (String.contains(s, "Cons"))
      end
    end

    test "ModuleInfo empty vs populated" do
      let empty = ModuleInfo("E", None, Nil, Nil, Nil, "")
      let full = ModuleInfo("F", Some("doc"), Cons(FnEntry("f", "", None, false, 0), Nil), Cons(TypeEntry("T", "", None, 0), Nil), Cons(IfaceEntry("I", "", None, Nil, 0), Nil), "")
      match empty do ModuleInfo(_, _, fs, ts, is, _) ->
        assert (List.is_empty(fs))
        assert (List.is_empty(ts))
        assert (List.is_empty(is))
      end
      match full do ModuleInfo(_, c, fs, ts, is, _) ->
        assert (!List.is_empty(fs))
        assert (!List.is_empty(ts))
        assert (!List.is_empty(is))
        match c do Some(t) -> assert (t == "doc") | None -> assert false end
      end
    end

    test "FnEntry private flags comprehensive" do
      let entries = Cons(FnEntry("a", "", None, false, 0), Cons(FnEntry("b", "", None, true, 0), Cons(FnEntry("c", "", None, false, 0), Cons(FnEntry("d", "", None, true, 0), Nil))))
      assert (List.length(entries) == 4)
      assert (Parser.is_pub(List.nth(entries, 0)))
      assert (Parser.is_prv(List.nth(entries, 1)))
      assert (Parser.is_pub(List.nth(entries, 2)))
      assert (Parser.is_prv(List.nth(entries, 3)))
    end

    test "info_name consistency" do
      let m = ModuleInfo("TestName", None, Nil, Nil, Nil, "")
      assert (Parser.info_name(m) == "TestName")
      assert (Parser.info_name(m) == Parser.info_name(m))
      assert (String.byte_size(Parser.info_name(m)) == 8)
    end

    test "FnEntry sig lengths" do
      let short = FnEntry("f", "f()", None, false, 0)
      let long = FnEntry("map", "map(lst : List(a), f : fn(a) : b) : List(b)", None, false, 0)
      match short do FnEntry(_, s, _, _, _) -> assert (String.byte_size(s) == 3) end
      match long do FnEntry(_, s, _, _, _) -> assert (String.byte_size(s) > 20) end
    end

    test "TypeEntry with and without doc" do
      let with_doc = TypeEntry("A", "A = X", Some("Has doc"), 0)
      let no_doc = TypeEntry("B", "B = Y", None, 0)
      match with_doc do TypeEntry(_, _, d, _) ->
        match d do Some(t) -> assert (t == "Has doc") | None -> assert false end
      end
      match no_doc do TypeEntry(_, _, d, _) -> assert (d == None) end
    end

    test "IfaceEntry with and without doc" do
      let with_doc = IfaceEntry("A", "A", Some("Has doc"), Nil, 0)
      let no_doc = IfaceEntry("B", "B", None, Nil, 0)
      match with_doc do IfaceEntry(_, _, d, _, _) ->
        match d do Some(t) -> assert (t == "Has doc") | None -> assert false end
      end
      match no_doc do IfaceEntry(_, _, d, _, _) -> assert (d == None) end
    end

    test "FnEntry doc string content" do
      let e = FnEntry("parse", "parse(s : String) : AST", Some("Parses a string into an AST node"), false, 0)
      match e do FnEntry(n, s, d, p, _) ->
        assert (n == "parse")
        assert (String.contains(s, "String"))
        assert (String.contains(s, "AST"))
        assert (p == false)
        match d do
          Some(t) ->
            assert (String.contains(t, "Parses"))
            assert (String.contains(t, "AST"))
            assert (String.byte_size(t) > 10)
          None -> assert false
        end
      end
    end

    test "ModuleInfo list lengths" do
      let fns3 = Cons(FnEntry("a", "", None, false, 0), Cons(FnEntry("b", "", None, false, 0), Cons(FnEntry("c", "", None, false, 0), Nil)))
      let types2 = Cons(TypeEntry("T1", "", None, 0), Cons(TypeEntry("T2", "", None, 0), Nil))
      let ifaces1 = Cons(IfaceEntry("I", "", None, Nil, 0), Nil)
      let m = ModuleInfo("M", None, fns3, types2, ifaces1, "")
      match m do ModuleInfo(_, _, fs, ts, is, _) ->
        assert (List.length(fs) == 3)
        assert (List.length(ts) == 2)
        assert (List.length(is) == 1)
        assert (List.length(fs) > List.length(ts))
        assert (List.length(ts) > List.length(is))
      end
    end

    test "entry_priv on list of entries" do
      let entries = Cons(FnEntry("a", "", None, false, 0), Cons(FnEntry("b", "", None, true, 0), Cons(FnEntry("c", "", None, false, 0), Nil)))
      let priv_count = List.length(List.filter(entries, fn e -> Parser.entry_priv(e)))
      let pub_count = List.length(List.filter(entries, fn e -> Parser.is_pub(e)))
      assert (priv_count == 1)
      assert (pub_count == 2)
      assert (priv_count + pub_count == 3)
    end

    test "ModuleInfo name extraction from various" do
      let modules = Cons(ModuleInfo("Alpha", None, Nil, Nil, Nil, ""), Cons(ModuleInfo("Beta", None, Nil, Nil, Nil, ""), Cons(ModuleInfo("Gamma", None, Nil, Nil, Nil, ""), Nil)))
      let names = List.map(modules, fn m -> Parser.info_name(m))
      assert (List.length(names) == 3)
      match List.head_opt(names) do
        Some(n) -> assert (n == "Alpha")
        None -> assert false
      end
    end

    test "FnEntry string operations" do
      let e = FnEntry("hello_world", "hello_world(name : String) : String", Some("Says hello"), false, 0)
      match e do FnEntry(n, s, d, _, _) ->
        assert (String.starts_with(n, "hello"))
        assert (String.ends_with(n, "world"))
        assert (String.contains(n, "_"))
        assert (String.byte_size(n) == 11)
        assert (String.contains(s, "name"))
        match d do Some(t) -> assert (String.starts_with(t, "Says")) | None -> assert false end
      end
    end

    test "TypeEntry string operations" do
      let t = TypeEntry("BinaryTree", "BinaryTree(a) = Leaf(a) | Node(BinaryTree(a), BinaryTree(a))", Some("A recursive tree type"), 0)
      match t do TypeEntry(n, s, d, _) ->
        assert (String.starts_with(n, "Binary"))
        assert (String.ends_with(n, "Tree"))
        assert (String.byte_size(n) == 10)
        assert (String.contains(s, "Leaf"))
        assert (String.contains(s, "Node"))
        assert (String.contains(s, "BinaryTree"))
        match d do
          Some(txt) ->
            assert (String.contains(txt, "recursive"))
            assert (String.contains(txt, "tree"))
          None -> assert false
        end
      end
    end

    test "IfaceEntry string operations" do
      let i = IfaceEntry("Serializable", "Serializable", Some("Converts to bytes"), Cons(("serialize", "fn serialize(self) : Bytes"), Nil), 0)
      match i do IfaceEntry(n, s, d, ms, _) ->
        assert (n == "Serializable")
        assert (s == "Serializable")
        assert (String.byte_size(n) == 12)
        assert (List.length(ms) == 1)
        match d do
          Some(txt) ->
            assert (String.contains(txt, "Converts"))
            assert (String.contains(txt, "bytes"))
          None -> assert false
        end
      end
    end

    test "mixed entry types in module" do
      let pub_fn = FnEntry("public_api", "public_api() : String", Some("Public API"), false, 0)
      let prv_fn = FnEntry("internal", "internal()", None, true, 0)
      let typ = TypeEntry("Config", "Config = Config(String, Int)", Some("Configuration"), 0)
      let iface = IfaceEntry("Plugin", "Plugin", Some("Plugin interface"), Nil, 0)
      assert (Parser.is_pub(pub_fn))
      assert (Parser.is_prv(prv_fn))
      assert (!Parser.is_pub(prv_fn))
      assert (!Parser.is_prv(pub_fn))
      match pub_fn do FnEntry(n, _, d, _, _) ->
        assert (n == "public_api")
        match d do Some(t) -> assert (String.contains(t, "Public")) | None -> assert false end
      end
      match typ do TypeEntry(n, s, d, _) ->
        assert (n == "Config")
        assert (String.contains(s, "String"))
        match d do Some(t) -> assert (t == "Configuration") | None -> assert false end
      end
      match iface do IfaceEntry(n, _, d, _, _) ->
        assert (n == "Plugin")
        match d do Some(t) -> assert (String.contains(t, "interface")) | None -> assert false end
      end
    end

    test "large module construction" do
      let fns = Cons(FnEntry("f1", "f1()", None, false, 0), Cons(FnEntry("f2", "f2()", Some("d2"), false, 0), Cons(FnEntry("f3", "f3()", None, true, 0), Cons(FnEntry("f4", "f4()", Some("d4"), true, 0), Cons(FnEntry("f5", "f5()", None, false, 0), Nil)))))
      let types = Cons(TypeEntry("T1", "T1 = A", None, 0), Cons(TypeEntry("T2", "T2 = B", Some("td"), 0), Cons(TypeEntry("T3", "T3 = C", None, 0), Nil)))
      let ifaces = Cons(IfaceEntry("I1", "I1", None, Nil, 0), Cons(IfaceEntry("I2", "I2", Some("id"), Nil, 0), Nil))
      let m = ModuleInfo("LargeMod", Some("A large module"), fns, types, ifaces, "")
      assert (Parser.info_name(m) == "LargeMod")
      match m do ModuleInfo(_, c, fs, ts, is, _) ->
        assert (List.length(fs) == 5)
        assert (List.length(ts) == 3)
        assert (List.length(is) == 2)
        match c do Some(t) -> assert (String.contains(t, "large")) | None -> assert false end
        let pub_fns = List.filter(fs, fn e -> Parser.is_pub(e))
        let prv_fns = List.filter(fs, fn e -> Parser.is_prv(e))
        assert (List.length(pub_fns) == 3)
        assert (List.length(prv_fns) == 2)
      end
    end

  end

  describe "parse_file basics" do

    test "parses valid module" do
      match parse_src("valid", "mod Sample do\nfn hello() do 42 end\nend", false) do
        None -> assert false
        Some(info) ->
          assert (Parser.info_name(info) == "Sample")
          match info do ModuleInfo(_, _, fns, _, _, _) -> assert (List.length(fns) == 1) end
      end
    end

    test "doc string on function" do
      match parse_src("doc1", "mod DT do\n\ndoc \"This is hello\"\nfn hello() do 42 end\n\nend", false) do
        None -> assert false
        Some(info) ->
          match info do ModuleInfo(_, _, fns, _, _, _) ->
            assert (List.length(fns) == 1)
            match List.head_opt(fns) do
              None -> assert false
              Some(e) -> match e do FnEntry(name, _, d, _, _) ->
                assert (name == "hello")
                assert (d == Some("This is hello"))
              end
            end
          end
      end
    end

    test "type declarations" do
      match parse_src("type1", "mod TT do\n\ntype Color = Red | Blue | Green\n\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, _, types, _, _) ->
          assert (List.length(types) == 1)
          match List.head_opt(types) do
            None -> assert false
            Some(te) -> match te do TypeEntry(name, s, _, _) ->
              assert (name == "Color")
              assert (String.contains(s, "Red"))
              assert (String.contains(s, "Blue"))
              assert (String.contains(s, "Green"))
            end
          end
        end
      end
    end

    test "excludes private by default" do
      match parse_src("excl", "mod PT do\npfn secret() do 42 end\nfn public_fn() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          assert (List.length(fns) == 1)
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(name, _, _, p, _) ->
              assert (name == "public_fn")
              assert (p == false)
            end
          end
        end
      end
    end

    test "includes private when flag set" do
      match parse_src("incl", "mod PT2 do\npfn secret() do 42 end\nfn pub() do 1 end\nend", true) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          assert (List.length(fns) == 2)
        end
      end
    end

    test "None for non-existent file" do
      match Parser.parse_file("/tmp/march_doc_no_such_file_ever.march", false) do
        None -> assert true
        Some(_) -> assert false
      end
    end

    test "module comment with spaces" do
      match parse_src("comment", "-- This module does things.\n-- It is useful.\n\nmod Co do\nfn foo() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, comment, _, _, _, _) ->
          match comment do
            None -> assert false
            Some(c) ->
              assert (String.contains(c, "This module does things"))
              assert (String.contains(c, "It is useful"))
          end
        end
      end
    end

    test "module comment without space" do
      match parse_src("nospace", "--NoSpace\n--Also\nmod Da do\nfn f() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, comment, _, _, _, _) ->
          match comment do
            None -> assert false
            Some(c) ->
              assert (String.contains(c, "NoSpace"))
              assert (String.contains(c, "Also"))
          end
        end
      end
    end

    test "triple-quoted doc string" do
      match parse_src("triple", "mod TT do\n\ndoc \"\"\"\nLine one.\nLine two.\n\"\"\"\nfn documented() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(_, _, d, _, _) ->
              match d do
                None -> assert false
                Some(txt) ->
                  assert (String.contains(txt, "Line one"))
                  assert (String.contains(txt, "Line two"))
              end
            end
          end
        end
      end
    end

    test "interface declaration" do
      match parse_src("iface", "mod IT do\ninterface Printable do\n  fn to_string(self) : String\nend\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, _, _, ifaces, _) ->
          assert (List.length(ifaces) == 1)
          match List.head_opt(ifaces) do
            None -> assert false
            Some(ie) -> match ie do IfaceEntry(name, s, _, _, _) ->
              assert (name == "Printable")
              assert (String.contains(s, "Printable"))
            end
          end
        end
      end
    end

    test "ptype declaration" do
      match parse_src("ptype", "mod Pt do\nptype Internal = A | B\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, _, types, _, _) ->
          match List.head_opt(types) do
            None -> assert false
            Some(te) -> match te do TypeEntry(name, s, _, _) ->
              assert (name == "Internal")
              assert (String.contains(s, "ptype"))
              assert (String.contains(s, "Internal"))
            end
          end
        end
      end
    end

    test "function signature" do
      match parse_src("st", "mod ST do\nfn add(a : Int, b : Int) : Int do a + b end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(name, s, _, _, _) ->
              assert (name == "add")
              assert (String.contains(s, "Int"))
              assert (String.contains(s, "add"))
              assert (String.ends_with(s, "do") == false)
            end
          end
        end
      end
    end

  end

  describe "parse_file edge cases" do

    test "empty file returns None" do
      match parse_src("ef", "", false) do
        None -> assert true
        Some(_) -> assert false
      end
    end

    test "no mod line returns None" do
      match parse_src("nomod", "-- just a comment\n", false) do
        None -> assert true
        Some(_) -> assert false
      end
    end

    test "Unknown module with fns returns Some" do
      match parse_src("nomod2", "fn foo() do 1 end\n", false) do
        None -> assert false
        Some(info) ->
          assert (Parser.info_name(info) == "Unknown")
          match info do ModuleInfo(_, _, fns, _, _, _) -> assert (List.length(fns) == 1) end
      end
    end

    test "module without declarations" do
      match parse_src("empty", "mod EmptyMod do\nend", false) do
        None -> assert false
        Some(info) ->
          assert (Parser.info_name(info) == "EmptyMod")
          match info do ModuleInfo(_, _, fns, types, ifaces, _) ->
            assert (List.is_empty(fns))
            assert (List.is_empty(types))
            assert (List.is_empty(ifaces))
          end
      end
    end

    test "nested function not extracted" do
      match parse_src("nested", "mod Ne do\nfn outer() do\n  fn inner() do 1 end\n  inner()\nend\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          assert (List.length(fns) == 1)
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(name, _, _, _, _) -> assert (name == "outer") end
          end
        end
      end
    end

    test "unterminated triple-quote" do
      match parse_src("unterm", "mod Un do\ndoc \"\"\"\nUnclosed\nfn foo() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) -> assert (List.length(fns) == 0) end
      end
    end

    test "comment-only file returns None" do
      match parse_src("conly", "-- Just a comment.\n-- Another line.\n", false) do
        None -> assert true
        Some(_) -> assert false
      end
    end

    test "unrecognized lines ignored" do
      match parse_src("ur", "mod UR do\nlet x = 42\nimport Foo\nfn f() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, types, ifaces, _) ->
          assert (List.length(fns) == 1)
          assert (List.length(types) == 0)
          assert (List.length(ifaces) == 0)
        end
      end
    end

    test "empty lines handled" do
      match parse_src("el", "mod EL do\n\n\n\nfn f() do 1 end\n\n\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) -> assert (List.length(fns) == 1) end
      end
    end

    test "doc attached across blank line" do
      match parse_src("orphan", "mod Or do\ndoc \"Orphaned\"\n\nfn f() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(_, _, d, _, _) -> assert (d == Some("Orphaned")) end
          end
        end
      end
    end

    test "comment with dashes only" do
      match parse_src("donly", "--\nmod Donly do\nfn f() do 1 end\nend", false) do
        None -> assert false
        Some(info) ->
          assert (Parser.info_name(info) == "Donly")
      end
    end

    test "pfn not toplevel excluded even with include" do
      match parse_src("pntl", "mod PNTL do\nfn outer() do\n  pfn nested() do 1 end\n  nested()\nend\nend", true) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          assert (List.length(fns) == 1)
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(name, _, _, _, _) -> assert (name == "outer") end
          end
        end
      end
    end

    test "tab indented nested fn excluded" do
      match parse_src("tab", "mod Tab do\nfn outer() do\n\tfn inner() do 1 end\n\tinner()\nend\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) -> assert (List.length(fns) == 1) end
      end
    end

  end

  describe "parse_file comprehensive" do

    test "comprehensive module" do
      let src = "-- A full module.\nmod Comp do\n\ndoc \"Function doc\"\nfn func(a : Int) : String do \"\" end\n\npfn priv_func() do 1 end\n\ndoc \"Type doc\"\ntype Color = Red | Blue\n\nptype Secret = X\n\ndoc \"Interface doc\"\ninterface Show do\n  fn show(self) : String\nend\n\nend"
      match parse_src("comp", src, true) do
        None -> assert false
        Some(info) ->
          assert (Parser.info_name(info) == "Comp")
          match info do ModuleInfo(name, comment, fns, types, ifaces, _) ->
            assert (name == "Comp")
            match comment do None -> assert false | Some(c) -> assert (String.contains(c, "full module")) end
            assert (List.length(fns) == 2)
            assert (List.length(types) == 2)
            assert (List.length(ifaces) == 1)
            -- Check first fn
            match List.head_opt(fns) do
              None -> assert false
              Some(e) -> match e do FnEntry(n, s, d, p, _) ->
                assert (n == "func")
                assert (String.contains(s, "Int"))
                assert (d == Some("Function doc"))
                assert (p == false)
              end
            end
            -- Check types
            match List.head_opt(types) do
              None -> assert false
              Some(te) -> match te do TypeEntry(n, s, d, _) ->
                assert (n == "Color")
                assert (d == Some("Type doc"))
                assert (String.contains(s, "Red"))
              end
            end
            -- Check ifaces
            match List.head_opt(ifaces) do
              None -> assert false
              Some(ie) -> match ie do IfaceEntry(n, _, d, _, _) ->
                assert (n == "Show")
                assert (d == Some("Interface doc"))
              end
            end
          end
      end
    end

    test "multiple functions in order" do
      match parse_src("multi", "mod Mu do\nfn a() do 1 end\nfn b() do 2 end\nfn c() do 3 end\nfn d() do 4 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          assert (List.length(fns) == 4)
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(name, _, _, _, _) -> assert (name == "a") end
          end
        end
      end
    end

    test "multiple types" do
      match parse_src("mt", "mod MT do\ntype A = X\ntype B = Y\ntype C = Z\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, _, types, _, _) -> assert (List.length(types) == 3) end
      end
    end

    test "types and functions together" do
      match parse_src("both", "mod Bo do\ntype T = A | B\nfn f() do 1 end\ntype U = C\nfn g() do 2 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, types, _, _) ->
          assert (List.length(fns) == 2)
          assert (List.length(types) == 2)
        end
      end
    end

    test "multiple pfn excluded" do
      match parse_src("pe", "mod PE do\npfn h1() do 1 end\nfn vis() do 2 end\npfn h2() do 3 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) -> assert (List.length(fns) == 1) end
      end
    end

    test "multiple pfn included" do
      match parse_src("pi", "mod PI do\npfn h1() do 1 end\nfn vis() do 2 end\npfn h2() do 3 end\nend", true) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          assert (List.length(fns) == 3)
        end
      end
    end

    test "fn and pfn interleaved with docs" do
      let src = "mod IP do\n\ndoc \"Pub 1\"\nfn pub1() do 1 end\n\ndoc \"Priv 1\"\npfn priv1() do 2 end\n\ndoc \"Pub 2\"\nfn pub2() do 3 end\n\nend"
      match parse_src("ip", src, true) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          assert (List.length(fns) == 3)
        end
      end
    end

    test "doc on type" do
      match parse_src("doctype", "mod DT2 do\ndoc \"A color\"\ntype Color = Red | Green\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, _, types, _, _) ->
          match List.head_opt(types) do
            None -> assert false
            Some(te) -> match te do TypeEntry(_, _, d, _) -> assert (d == Some("A color")) end
          end
        end
      end
    end

    test "doc on interface" do
      match parse_src("di", "mod DI do\ndoc \"Printable\"\ninterface Pr do\n  fn show(self) : String\nend\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, _, _, ifaces, _) ->
          match List.head_opt(ifaces) do
            None -> assert false
            Some(ie) -> match ie do IfaceEntry(_, _, d, _, _) -> assert (d == Some("Printable")) end
          end
        end
      end
    end

    test "doc on ptype" do
      match parse_src("dpt", "mod DPT do\ndoc \"Private type\"\nptype Internal = X | Y\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, _, types, _, _) ->
          match List.head_opt(types) do
            None -> assert false
            Some(te) -> match te do TypeEntry(name, s, d, _) ->
              assert (name == "Internal")
              assert (d == Some("Private type"))
              assert (String.contains(s, "ptype"))
            end
          end
        end
      end
    end

    test "multiple doc strings last applies" do
      match parse_src("md", "mod MD do\ndoc \"first\"\ndoc \"second\"\nfn f() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(_, _, d, _, _) -> assert (d == Some("second")) end
          end
        end
      end
    end

    test "doc cleared after use" do
      match parse_src("dc", "mod DC do\ndoc \"documented\"\nfn first() do 1 end\nfn second() do 2 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          assert (List.length(fns) == 2)
          let f2 = List.nth(fns, 1)
          match f2 do FnEntry(name, _, d, _, _) ->
            assert (name == "second")
            assert (d == None)
          end
        end
      end
    end

    test "comment-only lines preserve pending doc" do
      match parse_src("cp", "mod CP do\ndoc \"the doc\"\n-- comment line\nfn f() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(_, _, d, _, _) -> assert (d == Some("the doc")) end
          end
        end
      end
    end

    test "comment with blank line" do
      match parse_src("bc", "-- First.\n\n-- After blank.\nmod BC do\nfn f() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, comment, _, _, _, _) ->
          match comment do
            None -> assert false
            Some(c) -> assert (String.contains(c, "First"))
          end
        end
      end
    end

    test "module name with underscores" do
      match parse_src("und", "mod My_Module do\nfn f() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> assert (Parser.info_name(info) == "My_Module")
      end
    end

    test "multiple interfaces" do
      match parse_src("mi", "mod MI do\ninterface A do\n  fn a(self) : Int\nend\ninterface B do\n  fn b(self) : Int\nend\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, _, _, ifaces, _) -> assert (List.length(ifaces) == 2) end
      end
    end

    test "ptype and type together" do
      match parse_src("pt2", "mod PT2x do\ntype Pub = A\nptype Priv = B\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, _, types, _, _) -> assert (List.length(types) == 2) end
      end
    end

    test "triple doc on type" do
      match parse_src("tdt", "mod TDT do\ndoc \"\"\"\nA complex type.\nWith details.\n\"\"\"\ntype Shape = Circle | Square\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, _, types, _, _) ->
          match List.head_opt(types) do
            None -> assert false
            Some(te) -> match te do TypeEntry(name, _, d, _) ->
              assert (name == "Shape")
              match d do
                None -> assert false
                Some(txt) ->
                  assert (String.contains(txt, "complex type"))
                  assert (String.contains(txt, "details"))
              end
            end
          end
        end
      end
    end

    test "module comment ends at code" do
      match parse_src("mce", "-- Comment line 1.\n-- Comment line 2.\nmod MCE do\nfn f() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, comment, _, _, _, _) ->
          match comment do
            None -> assert false
            Some(c) ->
              assert (String.contains(c, "Comment line 1"))
              assert (String.contains(c, "Comment line 2"))
          end
        end
      end
    end

    test "doc string with special chars" do
      match parse_src("dsc", "mod DSC do\ndoc \"Returns a & b\"\nfn f() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(_, _, d, _, _) -> assert (d == Some("Returns a & b")) end
          end
        end
      end
    end

    test "doc with empty string" do
      match parse_src("des", "mod DES do\ndoc \"\"\nfn f() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(_, _, d, _, _) -> assert (d == Some("")) end
          end
        end
      end
    end

    test "triple doc empty content" do
      match parse_src("tde", "mod TDE do\ndoc \"\"\"\n\"\"\"\nfn f() do 1 end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(_, _, d, _, _) -> assert (d == Some("")) end
          end
        end
      end
    end

    test "triple doc on interface" do
      match parse_src("tdi", "mod TDI do\ndoc \"\"\"\nShows things.\n\"\"\"\ninterface Showable do\n  fn show(self) : String\nend\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, _, _, ifaces, _) ->
          match List.head_opt(ifaces) do
            None -> assert false
            Some(ie) -> match ie do IfaceEntry(name, _, d, _, _) ->
              assert (name == "Showable")
              match d do
                None -> assert false
                Some(txt) -> assert (String.contains(txt, "Shows things"))
              end
            end
          end
        end
      end
    end

    test "private function signature preserved" do
      match parse_src("pfs", "mod PFS do\npfn helper(x : Int, y : Int) : Int do x + y end\nend", true) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(name, s, _, priv, _) ->
              assert (name == "helper")
              assert (priv == true)
              assert (String.contains(s, "Int"))
              assert (String.ends_with(s, "do") == false)
            end
          end
        end
      end
    end

    test "complex function params" do
      match parse_src("fcp", "mod FCP do\nfn apply(f : fn(Int) : Int, x : Int) : Int do f(x) end\nend", false) do
        None -> assert false
        Some(info) -> match info do ModuleInfo(_, _, fns, _, _, _) ->
          match List.head_opt(fns) do
            None -> assert false
            Some(e) -> match e do FnEntry(name, s, _, _, _) ->
              assert (name == "apply")
              assert (String.contains(s, "fn"))
              assert (String.contains(s, "Int"))
            end
          end
        end
      end
    end

  end

end

end
